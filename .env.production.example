# Domain that should serve the app over HTTPS.
APP_DOMAIN=tierlistplus.example.com

# PostgreSQL credentials for the local Docker database.
POSTGRES_DB=tierlistplus
POSTGRES_USER=tierlistplus
POSTGRES_PASSWORD=CHANGE_ME_32_CHAR_ALNUM

# Required in production by src/lib/user-session.ts
SESSION_SECRET=CHANGE_ME_64_CHAR_ALNUM
# Optional during session secret rotation. Set to the old SESSION_SECRET for one deploy,
# then remove after active clients have been re-signed with the new SESSION_SECRET.
SESSION_SECRET_PREVIOUS=
